# appconfig
APP_NAME=spacecraft-cadet
# logger
LOG_LEVEL=info
# db / migrator
DATABASE_URL=postgres://bot:bot@localhost:5432/spacecraft?sslmode=disable
# discord bot (Developer Portal -> your app -> Bot -> Token)
BOT_TOKEN=
# command registration: "server" (instant, to DEV_SERVER_ID) or "global" (~1h)
COMMAND_SCOPE=server
DEV_SERVER_ID=
# features: comma-separated allowlist. Unset = all known features; empty = none.
FEATURES=ping
# ops HTTP server: /healthz (liveness), /readyz (readiness), /metrics
HEALTH_ADDR=:8080
