# appconfig
APP_NAME=spacecraft-corporation
# Process-wide timezone (IANA name, e.g. UTC, Europe/Berlin). Default UTC (GMT+0)
# so the app never inherits the host's local time. Drives log timestamps and the
# time.Now() the app writes into DB timestamp columns (stored in this zone).
APP_TIMEZONE=UTC
# Bot owner's Discord user ID (optional). When set, the bot mentions this owner
# in the reply it sends to commands from not-yet-approved servers.
#APP_OWNER_DISCORD_ID=
# i18n: default wording theme and language for servers that haven't chosen their
# own (per-server overrides via /settings). Must match a bundle under
# internal/i18n/locales/<theme>/<language>.json. Shipped: themes standard|lore,
# languages en|ru.
APP_THEME=standard
APP_LANGUAGE=en
# logger
LOG_LEVEL=info
# db / migrator
# Single source of truth for Postgres: the `postgres` container is configured
# from these, and the app assembles its DSN from the same POSTGRES_* values
# (db.Config.DSN), so there's no DATABASE_URL to keep in sync.
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot
POSTGRES_DB=spacecraft
# Connection target. Defaults (localhost:5432, sslmode=disable) suit running the
# bot/tests OUTSIDE Docker; under Docker compose sets POSTGRES_HOST=postgres.
#POSTGRES_HOST=localhost
#POSTGRES_PORT=5432
#POSTGRES_SSLMODE=disable
# Prod alternative: point POSTGRES_PASSWORD_FILE at a mounted secret file holding
# the password; env reads the file's contents. File wins (like BOT_TOKEN_FILE).
#POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
# Postgres image tag for the `postgres` container (compose default: 16).
#POSTGRES_VERSION=16
# Dev only (docker-compose.dev.yml): host port the dev Postgres publishes to.
# Override to avoid clashing with another local Postgres already on 5432. The
# in-container port and POSTGRES_PORT always use 5432.
#POSTGRES_HOST_PORT=5432
# discord bot token (Developer Portal -> your app -> Bot -> Token). SECRET.
# Dev: set BOT_TOKEN directly. Prod: prefer BOT_TOKEN_FILE -> a mounted secret
# file (Docker/K8s); env reads the file's contents. File wins if both are set.
BOT_TOKEN=
#BOT_TOKEN_FILE=/run/secrets/bot_token
# servers: comma-separated allowlist of Discord server (guild) IDs auto-approved
# on join. May be empty (nothing auto-approved). Only promotes to approved; never
# demotes, so a manual approval is preserved. Commands from unapproved servers
# are ignored. Commands register per-joined-server (instant), so no dev server ID.
APPROVED_SERVER_ID=
# features: comma-separated allowlist. Unset = all known features; empty = none.
# Known: ping; permissions (role-based command access control + /permissions).
# With permissions enabled, server owners/admins map roles to commands; without
# it, every command is open. Per-command default access is a code-level policy.
FEATURES=ping,permissions
# instrumentation HTTP server: /healthz (liveness), /readyz (readiness), /metrics.
# Isolated from the app port (8080 is reserved for the future admin API).
INSTRUMENTATION_ADDR=:9464

# --- Docker build / Compose substitution (not read by the Go app) ------------
# These have working defaults in the compose files; left commented so they don't
# silently override. Uncomment / set only when you need a specific value.
# Version tag baked into the binary via ldflags. Prod build arg (default
# 0.0.0-unspecified; CI sets the git SHA); dev env (default dev, picked up by air).
#APP_VERSION=0.0.0-dev
# Dev only (docker-compose.dev.yml build args): run the dev container as a user
# matching the host so bind-mounted files aren't root-owned. Defaults to 1000.
# Best set inline: UID=$(id -u) GID=$(id -g) docker compose -f docker-compose.dev.yml up --build
#UID=1000
#GID=1000
