# appconfig
APP_NAME=spacecraft-corporation
# Process-wide timezone (IANA name, e.g. UTC, Europe/Berlin). Default UTC (GMT+0)
# so the app never inherits the host's local time. Drives log timestamps and the
# time.Now() the app writes into DB timestamp columns (stored in this zone).
APP_TIMEZONE=UTC
# Bot owner's Discord user ID (optional). When set, the bot mentions this owner
# in the reply it sends to commands from not-yet-approved servers.
#APP_OWNER_DISCORD_ID=
# i18n: default wording theme and language for servers that haven't chosen their
# own (per-server overrides via /settings). Must match a bundle under
# internal/i18n/locales/<theme>/<language>.json. Shipped: themes standard|lore,
# languages en|ru.
APP_THEME=standard
APP_LANGUAGE=en
# logger
LOG_LEVEL=info
# db / migrator
# Single source of truth for Postgres: the `postgres` container is configured
# from these, and the app assembles its DSN from the same POSTGRES_* values
# (db.Config.DSN), so there's no DATABASE_URL to keep in sync.
POSTGRES_USER=bot
POSTGRES_PASSWORD=bot
POSTGRES_DB=spacecraft
# Connection target. Defaults (localhost:5432, sslmode=disable) suit running the
# bot/tests OUTSIDE Docker; under Docker compose sets POSTGRES_HOST=postgres.
#POSTGRES_HOST=localhost
#POSTGRES_PORT=5432
#POSTGRES_SSLMODE=disable
# Prod alternative: point POSTGRES_PASSWORD_FILE at a mounted secret file holding
# the password; env reads the file's contents. File wins (like BOT_TOKEN_FILE).
#POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
# Postgres image tag for the `postgres` container (compose default: 16).
#POSTGRES_VERSION=16
# Dev only (docker-compose.dev.yml): host port the dev Postgres publishes to.
# Override to avoid clashing with another local Postgres already on 5432. The
# in-container port and POSTGRES_PORT always use 5432.
#POSTGRES_HOST_PORT=5432
# discord bot token (Developer Portal -> your app -> Bot -> Token). SECRET.
# Dev: set BOT_TOKEN directly. Prod: prefer BOT_TOKEN_FILE -> a mounted secret
# file (Docker/K8s); env reads the file's contents. File wins if both are set.
BOT_TOKEN=
#BOT_TOKEN_FILE=/run/secrets/bot_token
# servers: comma-separated allowlist of Discord server (guild) IDs auto-approved
# on join. May be empty (nothing auto-approved). Only promotes to approved; never
# demotes, so a manual approval is preserved. Commands from unapproved servers
# are ignored. Commands register per-joined-server (instant), so no dev server ID.
APPROVED_SERVER_ID=
# features: comma-separated allowlist. Unset = all known features; empty = none.
# Known: ping; permissions (role-based command access control + /permissions);
# bases (member/corp base registry + /base, requires permissions — enabling it
# auto-enables permissions). With permissions enabled, server owners/admins map
# roles to commands; without it, every command is open. Per-command default
# access is a code-level policy.
FEATURES=ping,permissions,bases,contracts
# bases feature (only read when "bases" is enabled). In-game limits, mirrored
# here so they can be tuned: bases per member / per corporation, and equipment
# (extractors / production facilities) per base. PAGE_SIZE is the /base list page.
BASES_MEMBER_LIMIT=3
BASES_CORP_LIMIT=6
BASES_EXTRACTOR_LIMIT=4
BASES_PRODUCTION_LIMIT=30
BASES_LIST_PAGE_SIZE=8
# contracts feature (only read when "contracts" is enabled). SWEEP_INTERVAL is
# how often the background ticker runs (expiry + pre-expiry notice), so it is the
# scheduling granularity — keep it no longer than EXPIRES_NOTIFY. EXPIRES_NOTIFY
# is how long before the deadline the bot posts the one-shot "closing soon"
# comment pinging every participant. MAX_ITEMS caps the distinct required items
# per contract; PAGE_SIZE is the /contract list page. Each server picks its forum
# channel at runtime via /contract forum. (No refresh interval: the embed renders
# the deadline as a Discord timestamp the client keeps live, so open contracts
# need no periodic server-side re-render.)
CONTRACTS_SWEEP_INTERVAL=1m
CONTRACTS_EXPIRES_NOTIFY=1h
CONTRACTS_MAX_ITEMS=25
CONTRACTS_LIST_PAGE_SIZE=8
# outbox worker (core): the transactional-outbox queue that performs Discord side
# effects (contract thread create/refresh/close) off the interaction deadline.
# POLL_INTERVAL is how often the worker scans for due tasks; MAX_ATTEMPTS is how
# many times a task may fail before it is abandoned; BATCH_SIZE caps tasks per tick.
# CLEANUP_INTERVAL is how often terminal tasks past retention are purged;
# DONE/FAILED_RETENTION are how long completed / abandoned tasks are kept (Go
# duration syntax has no "d" unit, so 3d/10d are written as hours).
OUTBOX_POLL_INTERVAL=3s
OUTBOX_MAX_ATTEMPTS=10
OUTBOX_BATCH_SIZE=20
OUTBOX_CLEANUP_INTERVAL=1h
OUTBOX_DONE_RETENTION=72h
OUTBOX_FAILED_RETENTION=240h
# emoji (core): the bot's custom emojis are application emojis (owned by the bot,
# usable in every server). On start the bot always LISTS its application emojis to
# build a fast name->token map (so admin-uploaded emojis are picked up too).
# /readyz stays red until the first sync completes.
#
# EMOJI_UPLOAD is the master switch for managing emojis from the repo. When false
# (default) the bot is read-only. When true it uploads the images under
# internal/emoji/assets/ that are missing (idempotent), and the two toggles below
# apply. Leave it false in normal operation; flip to true for a one-shot deploy to
# publish changes.
EMOJI_UPLOAD=false
# EMOJI_PRUNE (default true, only acts when EMOJI_UPLOAD=true): delete application
# emojis whose name the repo no longer defines. Set false to keep them.
EMOJI_PRUNE=true
# EMOJI_REPLACE (default false, only acts when EMOJI_UPLOAD=true): force-replace
# every embedded emoji on each start. There is no change detection and an emoji's
# image can't be edited, so this deletes and recreates it (minting a NEW id) on
# EVERY boot. Enable it only for a one-shot deploy after changing an image, then
# turn it back off.
EMOJI_REPLACE=false
# gamedata (core): the compiled-in, versioned game reference data (items, contract
# templates, ...). Nothing is parsed at runtime; the data is generated Go under
# internal/gamedata/db/v*. GAMEDATA_VERSIONS is the comma-separated allowlist of
# versions to load (a version's ancestors load automatically). Unset = load every
# defined version; set-but-empty = load none. A listed-but-undefined version is
# warned and skipped. New links (e.g. contracts) are stamped with the newest
# loaded version. Pin older versions here so links stamped with them keep
# resolving after a breaking game update cuts a new version.
#GAMEDATA_VERSIONS=v1
# instrumentation HTTP server: /healthz (liveness), /readyz (readiness), /metrics.
# Isolated from the app port (8080 is reserved for the future admin API).
INSTRUMENTATION_ADDR=:9464

# --- Docker build / Compose substitution (not read by the Go app) ------------
# These have working defaults in the compose files; left commented so they don't
# silently override. Uncomment / set only when you need a specific value.
# gamedata generator only (dev/maintainer, NOT read by the running bot): the
# `generated/` folder of the public resources repo
# (https://github.com/kweezl/spacecraft-resources). Used by `make gamedata.gen`
# (go generate) to regenerate internal/gamedata/db/v* and the item icons. Clone
# that repo and point this at its generated/ dir.
#GAMEDATA_SOURCE=/path/to/spacecraft-resources/generated
# Prod (docker-compose.yml): which published Docker Hub tag to pull and run
# (kweezls/spacecraft-corporation:<IMAGE_TAG>). Default latest; pin a release with
# e.g. IMAGE_TAG=1.2.3. The image is built+pushed by CI on a vX.X.X git tag.
#IMAGE_TAG=latest
# Version tag baked into the binary via ldflags. CI release sets this build arg to
# the bare semver; dev env (default dev, picked up by air). Not used by prod
# compose (that pulls a prebuilt image — see IMAGE_TAG).
#APP_VERSION=0.0.0-dev
# Dev only (docker-compose.dev.yml build args): run the dev container as a user
# matching the host so bind-mounted files aren't root-owned. Defaults to 1000.
# Best set inline: UID=$(id -u) GID=$(id -g) docker compose -f docker-compose.dev.yml up --build
#UID=1000
#GID=1000
